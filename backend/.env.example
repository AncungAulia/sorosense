# SoroSense backend — environment template.
#
# Copy to `backend/.env` (gitignored) and fill in the values. VALUES BELOW ARE ELIDED ON PURPOSE:
# this file documents the *names*, never a key. Secrets (KEEPER_SECRET, FAUCET_ISSUER_SECRET,
# DEMO_DEPOSITOR_SECRET) are backend-only — they never reach a response body, a NEXT_PUBLIC_* var,
# or a commit.
#
# With none of these set the backend runs entirely on the in-memory MockVaultClient (the default: dev
# and the whole test suite, offline). The integration vars are what switch it to the deployed testnet
# contract.

# ── Network ─────────────────────────────────────────────────────────────────
# Soroban RPC (contract simulate/submit) and Horizon (classic: accounts, trustlines).
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
# Testnet only. The demo seed script hard-stops on any other passphrase.
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# ── Vault ───────────────────────────────────────────────────────────────────
# The deployed vault contract (C…). Required together with the RPC URL, the passphrase and
# KEEPER_SECRET for the backend to talk to the chain at all (isIntegrationEnv).
VAULT_CONTRACT_ID=
# Signs keeper/guard writes (allocate · rebalance · freeze · propose-exit). BACKEND-ONLY.
KEEPER_SECRET=

# ── Assets (self-issued testnet stablecoins, STE-46) ────────────────────────
# The SAC contract ids the faucet mints through, and the classic issuers behind them. The issuer is
# what the demo depositor signs a `changeTrust` to before the SAC mint can land; the script checks that
# each issuer actually derives its configured SAC.
USDC_SAC=
USDC_ISSUER=GDOWW3KRITEDQPL6UHB2NKT35UXY2HKXVYGWI47XZROI2KLBBTEWUL3T
EURC_SAC=
EURC_ISSUER=
# Signs the SAC mint as issuer/admin (POST /faucet and the demo seed script share this one path).
# BACKEND-ONLY — never in a response.
FAUCET_ISSUER_SECRET=

# ── Pools ───────────────────────────────────────────────────────────────────
# The demo pool address per currency bucket. Keyed to the seam's pool slug by the registry in
# `src/tools/vault.ts` — the ONE place a currency maps to a pool.
BLEND_POOL_USD=
BLEND_POOL_EUR=

# ── Demo seed script (`pnpm -C backend demo:seed`) ──────────────────────────
# The demo depositor. Leave EMPTY on a first run: the script generates a keypair, appends the secret to
# this file's real counterpart (backend/.env, gitignored), and prints only the public G… . Every later
# run reuses it, which is what makes the script idempotent. BACKEND-ONLY.
DEMO_DEPOSITOR_SECRET=

# ── Realtime loops (live mode only — see src/http/realtime.ts) ──────────────
# Stellar RPC has no event streaming, so "realtime" is two polls. ALL OPTIONAL, none is a secret:
# with the integration vars set the loops run on the defaults below; with them unset (mock mode) the
# loops are never constructed and the backend issues zero network calls.
#
# First ledger the event poll reads from. Leave EMPTY to derive it: current ledger − ~7 days of
# ledgers (the RPC's event-retention window), clamped to >= 1. Set it to the vault's deploy ledger
# only while the contract is younger than that window — a value outside it makes every poll fail.
VAULT_START_LEDGER=
# How often the vault's on-chain events are polled (ms). Default 10000.
EVENT_POLL_MS=10000
# How often a share-price snapshot is taken for the earnings chart (ms). Default 60000.
SNAPSHOT_INTERVAL_MS=60000

# ── FX (Reflector oracle, display-only) ─────────────────────────────────────
# Reflector is a Soroban ORACLE CONTRACT (SEP-40), not a REST API: the backend simulates
# `lastprice(Other(<symbol>))` on it (src/tools/price.ts). ALL OPTIONAL — the defaults below are the
# deployed testnet feed, and it is read over STELLAR_RPC_URL + STELLAR_NETWORK_PASSPHRASE above (with
# those unset the backend is in mock mode and never reads a price).
#
# The SEP-40 FX oracle. Its base() is USD, so a price IS that asset's USD rate.
REFLECTOR_ORACLE_ID=CCYOZJCOPG34LLQQ7N24YXBM7LL62R7ONMZ3G6WZAAYPB5OYKOMJRN63
# The feed's fixed-point scale — decimals() reads 14 on-chain (1.1443 USD/EURC ⇒ 114433043263595).
REFLECTOR_DECIMALS=14
#
# The oracle symbol per non-USD bucket. USD needs none: it IS the oracle's base (rate 1, no read).
# The feed quotes TOKEN symbols (assets(): USDC, EURC, XLM, …), so the euro bucket is priced as EURC —
# there is no EURUSD fiat pair on it, and no MXN symbol at all. Leave FX_SYMBOL_MXN empty: an
# unpriceable bucket fails closed with a typed error rather than being blended 1:1 into dollars. A
# failed FX read for a bucket that HOLDS value stays a typed error → non-200 → "unavailable"; never a
# silent $0. An empty/untouched bucket needs no rate (0 × rate = 0), so it never breaks the view.
FX_SYMBOL_EUR=EURC
FX_SYMBOL_MXN=

# ── HTTP surface ────────────────────────────────────────────────────────────
PORT=8787
FRONTEND_ORIGIN=http://localhost:3000
