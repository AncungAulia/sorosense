# ── SoroSense environment ──────────────────────────────────────────────
# Copy to `.env` and fill in. Never commit real secrets.

# AI gateway (backend — narration only; the allocator decisions are deterministic, KTD6).
# Default route is OpenRouter; the demo uses a Jatevo (OpenAI-compatible) endpoint instead.
OPENROUTER_API_KEY=
# Jatevo (OpenAI-compatible) — set SOROSENSE_MODEL to a Jatevo model id to use it.
SOROSENSE_MODEL=gpt-5.4-mini
JATEVO_BASE_URL=https://2.jatevo.ai/v1
JATEVO_API_KEY=

# Stellar network (testnet for the demo)
STELLAR_NETWORK=testnet
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org

# Keeper role that authorizes the on-chain Sentinel freeze (backend-held; never shipped to the client)
KEEPER_SECRET=
# stellar CLI key names for deploy (configure via `stellar keys add <name>`; used by deploy.ts)
ADMIN_IDENTITY=admin
KEEPER_IDENTITY=keeper

# Deployed contract IDs (filled by smart-contract/scripts/deploy.ts after testnet deploy)
VAULT_CONTRACT_ID=

# ── Vault deploy seam (KTD-SC1: swappable per-currency venue + token addresses) ──
# Faucet issuer (STE-46). For the testnet demo these are SELF-ISSUED assets coded
# USDC/EURC wrapped as SAC — NOT real Circle tokens. ISSUER_IDENTITY is a stellar
# CLI key name; its SECRET is backend-only (faucet POST /faucet) and never committed.
ISSUER_IDENTITY=ss-issuer
# Stablecoin SAC (SEP-41) contract ids per currency bucket
USDC_SAC=
EURC_SAC=
# Demo yield-pool contract ids per currency — the accruing `yield_pool` (U1) the keeper
# allocates into and whose on-chain rate_bps() the app quotes as the display APY. Set by
# scripts/deploy-yield-pool.ts. The legacy BLEND_POOL_* names still work as a fallback.
YIELD_POOL_USD=
YIELD_POOL_EUR=
BLEND_POOL_USD=
BLEND_POOL_EUR=
# Vault config (optional; deploy.ts defaults are sane for the demo)
PER_POOL_CAP=1000000000000
MIN_FIRST_DEPOSIT=1000000
VIRTUAL_OFFSET=1000

# Off-chain data sources
DEFINDEX_API_URL=https://api.defindex.io
DEFILLAMA_YIELDS_URL=https://yields.llama.fi
